{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SEMDL SSQ",
  "scopeName": "source.semdl.ssq",
  "patterns": [
    { "include": "#comments" },
    { "include": "#queryBlock" },
    { "include": "#entries" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#logicalOperators" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.semdl",
          "match": "#.*$"
        }
      ]
    },
    "queryBlock": {
      "patterns": [
        {
          "name": "meta.block.query.semdl",
          "match": "^(\\s*)(query)( +)(\\{)",
          "captures": {
            "2": { "name": "keyword.control.block.semdl" },
            "4": { "name": "punctuation.section.block.begin.semdl" }
          }
        },
        {
          "name": "punctuation.section.block.end.semdl",
          "match": "^\\s*(\\})"
        }
      ]
    },
    "entries": {
      "patterns": [
        {
          "name": "meta.entry.query.semdl",
          "match": "^(\\s*)(select|where|similar|return)(:)( *)(?=\\S)",
          "captures": {
            "2": { "name": "keyword.other.entry.semdl" },
            "3": { "name": "keyword.operator.assignment.semdl" }
          }
        },
        {
          "name": "constant.language.result-mode.semdl",
          "match": "(?<![A-Za-z0-9_-])\\b(?:matches|subgraph)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.semdl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.semdl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.semdl",
          "match": "(?<![A-Za-z0-9_-])-?\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.semdl",
          "match": "(?<![A-Za-z0-9_-])\\b(?:true|false)\\b"
        }
      ]
    },
    "logicalOperators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.semdl",
          "match": "(?<![A-Za-z0-9_-])\\b(?:and|or|not)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.semdl",
          "match": ">=|<=|=|>|<"
        },
        {
          "name": "punctuation.separator.key-value.semdl",
          "match": ":"
        },
        {
          "name": "punctuation.section.group.semdl",
          "match": "[{}()]"
        }
      ]
    }
  }
}
