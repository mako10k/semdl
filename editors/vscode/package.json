{
  "name": "semdl-vscode",
  "displayName": "SEMDL",
  "description": "VS Code extension for SEMDL syntax highlighting and initial TypeScript LSP support.",
  "version": "0.0.1",
  "publisher": "mako10k",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/mako10k/semdl.git"
  },
  "private": true,
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "semdl-ssd",
        "aliases": ["SEMDL SSD", "ssd"],
        "extensions": [".ssd"],
        "configuration": "./languages/ssd.language-configuration.json"
      },
      {
        "id": "semdl-ssm",
        "aliases": ["SEMDL SSM", "ssm"],
        "extensions": [".ssm"],
        "configuration": "./languages/ssm.language-configuration.json"
      },
      {
        "id": "semdl-ssq",
        "aliases": ["SEMDL SSQ", "ssq"],
        "extensions": [".ssq"],
        "configuration": "./languages/ssq.language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "semdl-ssd",
        "scopeName": "source.semdl.ssd",
        "path": "./syntaxes/semdl-ssd.tmLanguage.json"
      },
      {
        "language": "semdl-ssm",
        "scopeName": "source.semdl.ssm",
        "path": "./syntaxes/semdl-ssm.tmLanguage.json"
      },
      {
        "language": "semdl-ssq",
        "scopeName": "source.semdl.ssq",
        "path": "./syntaxes/semdl-ssq.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "semdl.showLanguageServerStatus",
        "title": "SEMDL: Show Language Server Status"
      }
    ]
  },
  "scripts": {
    "clean": "rm -rf out dist",
    "compile": "tsc -b tsconfig.json tsconfig.server.json",
    "watch": "tsc -b tsconfig.json tsconfig.server.json --watch",
    "check": "npm run compile",
    "test": "npm run compile && node --test out/server/**/*.test.js",
    "package:vsix": "npm run test && mkdir -p dist && vsce package --out dist/semdl-${npm_package_version}.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/node": "^22.15.31",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
