      "command": "ssd remove type:alternative docs/examples/minimal.ssd",
      "cwd": ".",
      "expected_exit": 2,
      "expected_stdout": "",
      "expected_stderr": "docs/examples/golden/remove-type-alternative.error.stderr",
      "notes": "multi-match selector fails by default"
    },
    {
      "id": "remove-referenced-assertion-A1",
      "command": "ssd remove id:A1 docs/examples/minimal.ssd",
      "cwd": ".",
      "expected_exit": 3,
      "expected_stdout": "",
      "expected_stderr": "docs/examples/golden/remove-id-A1.error.stderr",
      "notes": "referenced structural element cannot be removed"
    },
    {
      "id": "annotate-invalid-kind-note",
      "command": "ssd annotate id:H1 note \"補足\" docs/examples/minimal.ssd",
      "cwd": ".",
      "expected_exit": 2,
      "expected_stdout": "",
      "expected_stderr": "docs/examples/golden/annotate-invalid-kind.error.stderr",
      "notes": "annotation kind is validated before execution"
    }
  ]
}
