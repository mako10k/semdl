document HELP {
  title: "SEMDL Help Topic: reference add"
  command: "ssd add --help --format semdl"
  topic: "reference"
  target: "add"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference add"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference add"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd add <kind> <file> [field=value ...]`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "- `ssd add <kind> <file> [field=value ...] --dry-run`"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "Status:"
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "- The current slice supports inline structural kinds: `resource`, `segment`, `assertion`, `hypothesis`, `alternative`."
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- `provenance`, `annotation`, and sidecar-targeted add remain deferred."
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "- `ssd help troubleshooting`"
}

segment HELP_LINE_11 {
  source: HELP_TOPIC
  text_quote: "Sample:"
}

segment HELP_LINE_12 {
  source: HELP_TOPIC
  text_quote: "- `ssd add resource docs/examples/minimal.ssd id=R2 type=appendix label=月次売上補足 --dry-run`"
}
