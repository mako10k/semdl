document HELP {
  title: "SEMDL Help Topic: reference add"
  command: "ssd add --help --format semdl"
  topic: "reference"
  target: "add"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference add"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference add"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd add <kind> <file> [field=value ...]`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "- `ssd add <kind> <file> [field=value ...] --stdout`"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "- `ssd add <kind> <file> [field=value ...] --out <output.ssd> [--dry-run]`"
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "- `ssd add <kind> <file> [field=value ...] --dry-run`"
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- `ssd add <kind> <file> [field=value ...] --target sidecar [--dry-run]`"
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "Status:"
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "- Inline structural add supports: `resource`, `segment`, `assertion`, `hypothesis`, `alternative`. Structural add also supports canonical inline `--stdout` and `--out <output.ssd>`."
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "- Metadata-only add supports `annotation` and `provenance` with `--target sidecar` only."
}

segment HELP_LINE_11 {
  source: HELP_TOPIC
  text_quote: "- Metadata-only add is create-only: it creates missing sidecar fields, creates a paired `.ssm` when absent, and fails on existing field conflicts."
}

segment HELP_LINE_12 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_13 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_14 {
  source: HELP_TOPIC
  text_quote: "- `ssd help troubleshooting`"
}

segment HELP_LINE_15 {
  source: HELP_TOPIC
  text_quote: "Sample:"
}

segment HELP_LINE_16 {
  source: HELP_TOPIC
  text_quote: "- `ssd add resource docs/examples/minimal.ssd id=R2 type=appendix label=月次売上補足 --dry-run`"
}

segment HELP_LINE_17 {
  source: HELP_TOPIC
  text_quote: "- `ssd add resource docs/examples/minimal.ssd id=R2 type=appendix label=月次売上補足 --stdout`"
}

segment HELP_LINE_18 {
  source: HELP_TOPIC
  text_quote: "- `ssd add annotation docs/examples/minimal.ssd id=H1 kind=todo text=追加入力で主体を確認する --target sidecar --dry-run`"
}
