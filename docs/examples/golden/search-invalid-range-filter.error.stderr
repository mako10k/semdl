ERROR invalid_query_filter
command: ssd search docs/query/invalid-range-filter.ssq docs/examples/minimal.ssd
query_file: docs/query/invalid-range-filter.ssq
where: confidence > 0.8
reason: comparison operators other than '=' are not supported in the current .ssq filter profile
allowed:
  - field
  - field = "value"
  - field = 1
  - field = true|false
hint: see `ssd help reference search`
