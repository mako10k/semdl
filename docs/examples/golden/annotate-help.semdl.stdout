document HELP {
  title: "SEMDL Help Topic: reference annotate"
  command: "ssd annotate --help --format semdl"
  topic: "reference"
  target: "annotate"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference annotate"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference annotate"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate <selector> <kind> <text> --target inline|sidecar|auto <file>`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate <selector> <kind> <text> --target inline|sidecar|auto --dry-run <file>`"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate <selector> <kind> <text> --target inline|sidecar|auto --stdout <file>`"
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate <selector> <kind> <text> --target inline|sidecar|auto --out <output-file> <file>`"
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate <selector> <kind> <text> --target inline|sidecar|auto --out <output-file> --dry-run <file>`"
}

