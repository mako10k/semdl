document HELP {
  title: "SEMDL Help Topic: reference annotate"
  command: "ssd annotate --help --format semdl"
  topic: "reference"
  target: "annotate"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference annotate"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference annotate"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate <selector> <kind> <text> --target inline|sidecar|auto <file>`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate <selector> <kind> <text> --target inline|sidecar|auto --dry-run <file>`"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "Purpose:"
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "- Write or preview one rationale, caveat, todo, status, or explanation field in inline or sidecar metadata."
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- `--target inline` is currently limited to standalone input and `assertion` / `hypothesis` targets."
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "- `--target auto` uses sidecar on paired input and otherwise prefers inline only where that standalone inline form is supported."
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "- Use `ssd add annotation ... --target sidecar` when you need create-only field-map semantics."
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_11 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_12 {
  source: HELP_TOPIC
  text_quote: "- `ssd help samples`"
}

segment HELP_LINE_13 {
  source: HELP_TOPIC
  text_quote: "Sample:"
}

segment HELP_LINE_14 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate id:H1 todo 追加入力で主体を確認する --target inline docs/examples/minimal.inline.ssd`"
}

segment HELP_LINE_15 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate id:R1 rationale 参照元を追記する --target auto docs/examples/minimal.ssd`"
}
