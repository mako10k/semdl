segment HELP_LINE_11 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate id:<id>,id:<id>,... <kind> <text> --target inline --out <output-file> <file>`"
}

segment HELP_LINE_12 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate id:<id>,id:<id>,... <kind> <text> --target inline --out <output-file> --dry-run <file>`"
}

segment HELP_LINE_13 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate id:<id>,id:<id>,... <kind> <text> --target sidecar <file>`"
}

segment HELP_LINE_14 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate id:<id>,id:<id>,... <kind> <text> --target sidecar --dry-run <file>`"
}

segment HELP_LINE_15 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate id:<id>,id:<id>,... <kind> <text> --target sidecar --stdout <file>`"
}

segment HELP_LINE_16 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate id:<id>,id:<id>,... <kind> <text> --target sidecar --out <output-file> <file>`"
}

segment HELP_LINE_17 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate id:<id>,id:<id>,... <kind> <text> --target sidecar --out <output-file> --dry-run <file>`"
}

segment HELP_LINE_18 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate type:<kind> <kind> <text> --target sidecar --allow-multi <file>`"
}

segment HELP_LINE_19 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate type:<kind> <kind> <text> --target sidecar --allow-multi --dry-run <file>`"
}

segment HELP_LINE_20 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate type:<kind> <kind> <text> --target sidecar --allow-multi --stdout <file>`"
}

segment HELP_LINE_21 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate type:<kind> <kind> <text> --target sidecar --allow-multi --out <output-file> <file>`"
}

segment HELP_LINE_22 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate type:<kind> <kind> <text> --target sidecar --allow-multi --out <output-file> --dry-run <file>`"
}

segment HELP_LINE_23 {
  source: HELP_TOPIC
  text_quote: "Purpose:"
}

segment HELP_LINE_24 {
  source: HELP_TOPIC
  text_quote: "- Write, preview, or emit one rationale, caveat, todo, status, or explanation field in Solo mode or Sidekick metadata."
}

segment HELP_LINE_25 {
  source: HELP_TOPIC
  text_quote: "- `--target inline` is currently limited to standalone input and `assertion` / `hypothesis` targets."
}

segment HELP_LINE_26 {
  source: HELP_TOPIC
  text_quote: "- `--target auto` uses Sidekick on paired input and otherwise prefers Solo mode only where that standalone form is supported."
}

segment HELP_LINE_27 {
  source: HELP_TOPIC
  text_quote: "- explicit annotate id lists are limited to comma-separated `id:` atoms and currently require `--target inline` or `--target sidecar`."
}

segment HELP_LINE_28 {
  source: HELP_TOPIC
  text_quote: "- `type:<kind>` annotate is currently limited to Sidekick output and requires `--allow-multi` even when one target matches."
}

segment HELP_LINE_29 {
  source: HELP_TOPIC
  text_quote: "- `--stdout` and `--out` return the canonical text for the resolved mode."
}

segment HELP_LINE_30 {
  source: HELP_TOPIC
  text_quote: "- Use `ssd add annotation ... --target sidecar` when you need create-only field-map semantics."
}

segment HELP_LINE_31 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_32 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_33 {
  source: HELP_TOPIC
  text_quote: "- `ssd help samples`"
}

segment HELP_LINE_34 {
  source: HELP_TOPIC
  text_quote: "Sample:"
}

segment HELP_LINE_35 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate id:H1 todo 追加入力で主体を確認する --target inline docs/examples/minimal.inline.ssd`"
}

segment HELP_LINE_36 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate id:H1 status 検証待ち --target inline --stdout docs/examples/minimal.inline.ssd`"
}

segment HELP_LINE_37 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate id:R1 rationale 参照元を追記する --target auto docs/examples/minimal.ssd`"
}

segment HELP_LINE_38 {
  source: HELP_TOPIC
  text_quote: "- `ssd annotate type:alternative rationale 候補を再確認する --target sidecar --allow-multi docs/examples/minimal.ssd`"
}
