ERROR invalid_query_filter
command: ssd search docs/query/invalid-tab-filter.ssq.txt docs/examples/minimal.ssd
query_file: docs/query/invalid-tab-filter.ssq.txt
where: 	confidence	=	1
reason: tab characters are not supported in the current .ssq filter profile
allowed:
  - field
  - field = "value"
  - field = 1
  - field = true|false
  - field > 0.8
  - not field
  - not field = true
  - field and other = true
  - not (field or other)
  - field and other = true or third
  - (field or other) and third > 0.8
hint: see `ssd help reference search`
