ERROR invalid_query_filter
command: ssd search docs/query/invalid-tab-filter.ssq docs/examples/minimal.ssd
query_file: docs/query/invalid-tab-filter.ssq
where: 	confidence	=	1
reason: tab characters are not supported in the current .ssq filter profile
allowed:
  - field
  - field = "value"
  - field = 1
  - field = true|false
  - field > 0.8
  - field and other = true
  - field > 0.8 or other
hint: see `ssd help reference search`
