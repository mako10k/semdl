ERROR invalid_query_filter
command: ssd search docs/query/invalid-leading-dot-number-filter.ssq docs/examples/minimal.ssd
query_file: docs/query/invalid-leading-dot-number-filter.ssq
where: confidence = .5
reason: equality checks must use a quoted string, number, or boolean on the right-hand side
allowed:
  - field
  - field = "value"
  - field = 1
  - field = true|false
hint: see `ssd help reference search`
