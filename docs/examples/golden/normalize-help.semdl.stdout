document HELP {
  title: "SEMDL Help Topic: reference normalize"
  command: "ssd normalize --help --format semdl"
  topic: "reference"
  target: "normalize"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference normalize"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference normalize"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd normalize <input.ssd> [--stdout]`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "- `ssd normalize <input.ssd> --dry-run`"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "- `ssd normalize <input.ssd> --out <output.ssd> [--dry-run]`"
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "Status:"
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- `--stdout` returns canonical inline output from `.ssd` with an optional paired `.ssm`."
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "- Bare apply and `--dry-run` rewrite or preview canonical inline output at the input path; paired input removes the sibling `.ssm`."
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "- `--out <output.ssd>` writes canonical inline output without modifying the source `.ssd` or paired `.ssm`."
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_11 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_12 {
  source: HELP_TOPIC
  text_quote: "- `ssd help troubleshooting`"
}

segment HELP_LINE_13 {
  source: HELP_TOPIC
  text_quote: "Sample:"
}

segment HELP_LINE_14 {
  source: HELP_TOPIC
  text_quote: "- `ssd normalize docs/examples/normalize-source.ssd --out docs/examples/normalized-output.ssd`"
}
