document HELP {
  title: "SEMDL Help Topic: reference normalize"
  command: "ssd normalize --help --format semdl"
  topic: "reference"
  target: "normalize"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference normalize"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference normalize"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd normalize <input.ssd> [--stdout]`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "- `ssd normalize <input.ssd> --dry-run [--format inline|sidecar]`"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "- `ssd normalize <input.ssd> --out <output.ssd> [--format inline|sidecar] [--dry-run]`"
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "Status:"
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- `--stdout` returns canonical inline output from `.ssd` with an optional paired `.ssm`."
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "- Bare apply remains inline-only and removes the sibling `.ssm` on paired input after writing canonical inline output."
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "- `--dry-run` and `--out` default to inline output, but `--format sidecar` previews or writes a split `.ssd` + `.ssm` pair without modifying the source files."
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "- `--stdout` and bare apply do not accept `--format` in this slice."
}

segment HELP_LINE_11 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_12 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_13 {
  source: HELP_TOPIC
  text_quote: "- `ssd help troubleshooting`"
}

segment HELP_LINE_14 {
  source: HELP_TOPIC
  text_quote: "Sample:"
}

segment HELP_LINE_15 {
  source: HELP_TOPIC
  text_quote: "- `ssd normalize docs/examples/normalize-source.ssd --out docs/examples/normalized-output.ssd`"
}

segment HELP_LINE_16 {
  source: HELP_TOPIC
  text_quote: "- `ssd normalize docs/examples/normalize-source.ssd --out docs/examples/normalized-sidecar.ssd --format sidecar`"
}
