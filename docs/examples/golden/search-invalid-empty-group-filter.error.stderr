ERROR invalid_query_filter
command: ssd search docs/query/invalid-empty-group-filter.ssq docs/examples/minimal.ssd
query_file: docs/query/invalid-empty-group-filter.ssq
where: () or source_presence
reason: parenthesized groups must contain a filter expression
allowed:
  - field
  - field = "value"
  - field = 1
  - field = true|false
  - field > 0.8
  - field and other = true
  - field > 0.8 or other
  - field and other = true or third
  - (field or other) and third > 0.8
hint: see `ssd help reference search`
