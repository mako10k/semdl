document HELP {
  title: "SEMDL Help Topic: reference merge"
  command: "ssd merge --help --format semdl"
  topic: "reference"
  target: "merge"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference merge"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference merge"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd merge <input.ssd> --stdout`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "Purpose:"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "- Produce the merged inline view of `.ssd` plus paired `.ssm`."
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "- `ssd help samples`"
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "Sample:"
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "- `ssd merge docs/examples/minimal.ssd --stdout`"
}
