document HELP {
  title: "SEMDL Help Topic: reference merge"
  command: "ssd merge --help --format semdl"
  topic: "reference"
  target: "merge"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference merge"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference merge"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd merge <input.ssd> --stdout`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "- `ssd merge <input.ssd>`"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "- `ssd merge <input.ssd> --dry-run`"
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "- `ssd merge <input.ssd> --out <output.ssd> [--dry-run]`"
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- `ssd merge <input.ssd> [--stdout|--dry-run|--out <output.ssd> [--dry-run]] --fail-on-conflict`"
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "Status:"
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "- `--stdout` returns the merged inline view of `.ssd` with an optional paired `.ssm`."
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "- Bare apply and `--dry-run` require a paired `.ssm`; in-place apply removes that sidecar after writing inline output."
}

segment HELP_LINE_11 {
  source: HELP_TOPIC
  text_quote: "- `--out <output.ssd>` writes merged inline output without modifying the source `.ssd` or paired `.ssm`."
}

segment HELP_LINE_12 {
  source: HELP_TOPIC
  text_quote: "- `--fail-on-conflict` fails before output or mutation when inline source and paired sidecar disagree on the same sidecar-owned field; without it, paired `.ssm` keeps precedence."
}

segment HELP_LINE_13 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_14 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_15 {
  source: HELP_TOPIC
  text_quote: "- `ssd help samples`"
}

segment HELP_LINE_16 {
  source: HELP_TOPIC
  text_quote: "Sample:"
}

segment HELP_LINE_17 {
  source: HELP_TOPIC
  text_quote: "- `ssd merge docs/examples/minimal.ssd --stdout`"
}

segment HELP_LINE_18 {
  source: HELP_TOPIC
  text_quote: "- `ssd merge docs/examples/minimal.ssd --out docs/examples/merged-output.ssd --dry-run`"
}

segment HELP_LINE_19 {
  source: HELP_TOPIC
  text_quote: "- `ssd merge docs/examples/merge-conflict-source.ssd --stdout --fail-on-conflict`"
}
