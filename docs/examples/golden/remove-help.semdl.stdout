document HELP {
  title: "SEMDL Help Topic: reference remove"
  command: "ssd remove --help --format semdl"
  topic: "reference"
  target: "remove"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference remove"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference remove"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd remove <selector> <file>`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "- `ssd remove type:<kind> --allow-multi <file>`"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "Purpose:"
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "- Remove one sidecar metadata field or subtree when the selector resolves safely."
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- Structural multi-target and reference-breaking removals still fail."
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "- `ssd help recipes wrong-layer`"
}

segment HELP_LINE_11 {
  source: HELP_TOPIC
  text_quote: "Sample:"
}

segment HELP_LINE_12 {
  source: HELP_TOPIC
  text_quote: "- `ssd remove meta:A1.embedding docs/examples/minimal.ssd`"
}
