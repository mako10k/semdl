document HELP {
  title: "SEMDL Help Topic: reference similarity"
  command: "ssd similarity --help --format semdl"
  topic: "reference"
  target: "similarity"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference similarity"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference similarity"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd similarity <id> <id> <file>`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "Behavior:"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "- Compare two existing semantic targets in one input document using precomputed embeddings only."
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "- The current slice uses cosine similarity and requires matching model and dimensions."
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- Both inline `vector` and external `vector_ref` embedding records are supported."
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "- `ssd help troubleshooting`"
}
