document HELP {
  title: "SEMDL Help Topic: reference search"
  command: "ssd search --help --format semdl"
  topic: "reference"
  target: "search"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference search"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference search"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd search <query.ssq> <file>...`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "Status:"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "- This subcommand currently supports `select`, an optional single `where`, target-based `similar`, `return: matches`, and grouped `return: subgraph`."
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "- `where` accepts presence checks, scalar equality, numeric range comparisons, mixed `and`/`or` boolean expressions, and parenthesized grouping; `not` and function calls remain outside this slice."
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- `similar` uses precomputed embeddings from the integrated input view and excludes the anchor target from results."
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "- `similar` with `return: subgraph` reuses the grouped subgraph shape and includes top-level similarity metadata plus per-group scores."
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_11 {
  source: HELP_TOPIC
  text_quote: "- `ssd help troubleshooting`"
}
