document HELP {
  title: "SEMDL Help Topic: reference split"
  command: "ssd split --help --format semdl"
  topic: "reference"
  target: "split"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference split"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference split"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd split <input.ssd>`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "- `ssd split <input.ssd> --dry-run`"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "Purpose:"
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "- Separate Sidekick-eligible metadata into a paired Sidekick `.ssm` while preserving the Canvas skeleton in `.ssd`."
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- `--dry-run` previews what stays in `.ssd` and what moves to `.ssm`."
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "- `ssd help samples`"
}

segment HELP_LINE_11 {
  source: HELP_TOPIC
  text_quote: "Sample:"
}

segment HELP_LINE_12 {
  source: HELP_TOPIC
  text_quote: "- `ssd split docs/examples/minimal.inline.ssd`"
}
