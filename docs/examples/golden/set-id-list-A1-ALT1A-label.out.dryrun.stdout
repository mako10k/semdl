DRY-RUN
command: ssd set id:A1,id:ALT1A label "確認対象" --out docs/examples/set-id-list-output.ssd docs/examples/minimal.ssd
target_profile: inline
target_file: docs/examples/set-id-list-output.ssd
selector: id:A1,id:ALT1A
field: label
targets:
  - A1 old: "売上増加"
  - ALT1A old: "国内売上が増加した"
new: "確認対象"
preserve_source_ssd: docs/examples/minimal.ssd
preserve_source_ssm: docs/examples/minimal.ssm
changes: 2
