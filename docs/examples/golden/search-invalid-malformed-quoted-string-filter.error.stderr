ERROR invalid_query_filter
command: ssd search docs/query/invalid-malformed-quoted-string-filter.ssq.txt docs/examples/minimal.ssd
query_file: docs/query/invalid-malformed-quoted-string-filter.ssq.txt
where: label = "A"tail
reason: equality checks must use a quoted string, number, or boolean on the right-hand side
allowed:
  - field
  - field = "value"
  - field = 1
  - field = true|false
  - field > 0.8
  - not field
  - not field = true
  - field and other = true
  - not (field or other)
  - field and other = true or third
  - (field or other) and third > 0.8
hint: see `ssd help reference search`
