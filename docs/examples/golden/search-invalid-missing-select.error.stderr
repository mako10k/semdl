ERROR invalid_query_filter
command: ssd search docs/query/invalid-missing-select.ssq.txt docs/examples/minimal.ssd
query_file: docs/query/invalid-missing-select.ssq.txt
select: <missing>
reason: select is required
allowed:
  - field
  - field = "value"
  - field = 1
  - field = true|false
  - field > 0.8
  - not field
  - not field = true
  - field and other = true
  - not (field or other)
  - field and other = true or third
  - (field or other) and third > 0.8
hint: see `ssd help reference search`
