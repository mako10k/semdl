ERROR invalid_query_filter
command: ssd search docs/query/invalid-missing-select.ssq docs/examples/minimal.ssd
query_file: docs/query/invalid-missing-select.ssq
select: <missing>
reason: select is required
allowed:
  - field
  - field = "value"
  - field = 1
  - field = true|false
  - field > 0.8
  - field and other = true
  - field > 0.8 or other
hint: see `ssd help reference search`
