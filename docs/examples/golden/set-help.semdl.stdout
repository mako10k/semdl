segment HELP_LINE_21 {
  source: HELP_TOPIC
  text_quote: "- `ssd set id:<id>,id:<id>,... <field> <value> --out <output-file> <file>`"
}

segment HELP_LINE_22 {
  source: HELP_TOPIC
  text_quote: "- `ssd set id:<id>,id:<id>,... <field> <value> --out <output-file> --dry-run <file>`"
}

segment HELP_LINE_23 {
  source: HELP_TOPIC
  text_quote: "- `ssd set type:<kind> <field> <value> --allow-multi <file>`"
}

segment HELP_LINE_24 {
  source: HELP_TOPIC
  text_quote: "- `ssd set type:<kind> <field> <value> --allow-multi --dry-run <file>`"
}

segment HELP_LINE_25 {
  source: HELP_TOPIC
  text_quote: "- `ssd set type:<kind> <field> <value> --allow-multi --stdout <file>`"
}

segment HELP_LINE_26 {
  source: HELP_TOPIC
  text_quote: "- `ssd set type:<kind> <field> <value> --allow-multi --out <output-file> <file>`"
}

segment HELP_LINE_27 {
  source: HELP_TOPIC
  text_quote: "- `ssd set type:<kind> <field> <value> --allow-multi --out <output-file> --dry-run <file>`"
}

segment HELP_LINE_28 {
  source: HELP_TOPIC
  text_quote: "Purpose:"
}

segment HELP_LINE_29 {
  source: HELP_TOPIC
  text_quote: "- Apply, preview, or emit one target field update, or one explicit id-list / type allow-multi Solo mode field update set, in Solo mode structure or Sidekick metadata."
}

segment HELP_LINE_30 {
  source: HELP_TOPIC
  text_quote: "- `path:` and current `id:` updates use canonical Solo mode Canvas `.ssd` for `--stdout` and `--out`."
}

segment HELP_LINE_31 {
  source: HELP_TOPIC
  text_quote: "- explicit id lists are limited to comma-separated `id:` atoms and currently preserve Solo mode id field ownership."
}

segment HELP_LINE_32 {
  source: HELP_TOPIC
  text_quote: "- `type:<kind>` set is limited to Solo mode-owned fields and currently requires `--allow-multi` even when one target matches."
}

segment HELP_LINE_33 {
  source: HELP_TOPIC
  text_quote: "- `meta:` updates use canonical Sidekick `.ssm` for `--stdout` and `--out`."
}

segment HELP_LINE_34 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_35 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_36 {
  source: HELP_TOPIC
  text_quote: "- `ssd help recipes wrong-layer`"
}

segment HELP_LINE_37 {
  source: HELP_TOPIC
  text_quote: "Sample:"
}

segment HELP_LINE_38 {
  source: HELP_TOPIC
  text_quote: "- `ssd set meta:A1.confidence 0.91 docs/examples/minimal.ssd`"
}

segment HELP_LINE_39 {
  source: HELP_TOPIC
  text_quote: "- `ssd set path:A1.label 売上報告書 --stdout docs/examples/minimal.ssd`"
}
