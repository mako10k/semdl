document HELP {
  title: "SEMDL Help Topic: reference set"
  command: "ssd set --help --format semdl"
  topic: "reference"
  target: "set"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference set"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference set"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd set path:<id>.<field> <value> <file>`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "- `ssd set path:<id>.<field> <value> --dry-run <file>`"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "- `ssd set path:<id>.<field> <value> --stdout <file>`"
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "- `ssd set path:<id>.<field> <value> --out <output-file> <file>`"
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- `ssd set path:<id>.<field> <value> --out <output-file> --dry-run <file>`"
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "- `ssd set meta:<id>.<field> <value> <file>`"
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "- `ssd set meta:<id>.<field> <value> --dry-run <file>`"
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "- `ssd set meta:<id>.<field> <value> --stdout <file>`"
}

segment HELP_LINE_11 {
  source: HELP_TOPIC
  text_quote: "- `ssd set meta:<id>.<field> <value> --out <output-file> <file>`"
}

segment HELP_LINE_12 {
  source: HELP_TOPIC
  text_quote: "- `ssd set meta:<id>.<field> <value> --out <output-file> --dry-run <file>`"
}

segment HELP_LINE_13 {
  source: HELP_TOPIC
  text_quote: "- `ssd set id:<id> <field> <value> <file>`"
}

segment HELP_LINE_14 {
  source: HELP_TOPIC
  text_quote: "- `ssd set id:<id> <field> <value> --dry-run <file>`"
}

segment HELP_LINE_15 {
  source: HELP_TOPIC
  text_quote: "- `ssd set id:<id> <field> <value> --stdout <file>`"
}

segment HELP_LINE_16 {
  source: HELP_TOPIC
  text_quote: "- `ssd set id:<id> <field> <value> --out <output-file> <file>`"
}

segment HELP_LINE_17 {
  source: HELP_TOPIC
  text_quote: "- `ssd set id:<id> <field> <value> --out <output-file> --dry-run <file>`"
}

segment HELP_LINE_18 {
  source: HELP_TOPIC
  text_quote: "Purpose:"
}

segment HELP_LINE_19 {
  source: HELP_TOPIC
  text_quote: "- Apply, preview, or emit one target field update in inline structure or sidecar metadata."
}

segment HELP_LINE_20 {
  source: HELP_TOPIC
  text_quote: "- `path:` and current `id:` updates use canonical inline `.ssd` for `--stdout` and `--out`."
}

segment HELP_LINE_21 {
  source: HELP_TOPIC
  text_quote: "- `meta:` updates use canonical sidecar `.ssm` for `--stdout` and `--out`."
}

segment HELP_LINE_22 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_23 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_24 {
  source: HELP_TOPIC
  text_quote: "- `ssd help recipes wrong-layer`"
}

segment HELP_LINE_25 {
  source: HELP_TOPIC
  text_quote: "Sample:"
}

segment HELP_LINE_26 {
  source: HELP_TOPIC
  text_quote: "- `ssd set meta:A1.confidence 0.91 docs/examples/minimal.ssd`"
}

segment HELP_LINE_27 {
  source: HELP_TOPIC
  text_quote: "- `ssd set path:A1.label 売上報告書 --stdout docs/examples/minimal.ssd`"
}
