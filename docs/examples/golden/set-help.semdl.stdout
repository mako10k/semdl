  source: HELP_TOPIC
  text_quote: "- `ssd set id:<id>,id:<id>,... <field> <value> --dry-run <file>`"
}

segment HELP_LINE_20 {
  source: HELP_TOPIC
  text_quote: "- `ssd set id:<id>,id:<id>,... <field> <value> --stdout <file>`"
