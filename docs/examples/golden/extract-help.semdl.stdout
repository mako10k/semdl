document HELP {
  title: "SEMDL Help Topic: reference extract"
  command: "ssd extract --help --format semdl"
  topic: "reference"
  target: "extract"
  format: "semdl"
}

resource HELP_TOPIC {
  type: help-topic
  label: "reference extract"
}

segment HELP_LINE_1 {
  source: HELP_TOPIC
  text_quote: "SEMDL Help Topic: reference extract"
}

segment HELP_LINE_2 {
  source: HELP_TOPIC
  text_quote: "Usage:"
}

segment HELP_LINE_3 {
  source: HELP_TOPIC
  text_quote: "- `ssd extract --out <output.ssd> --embed-provider ollama --embed-model <model> <input.ssd>`"
}

segment HELP_LINE_4 {
  source: HELP_TOPIC
  text_quote: "- `ssd extract --stdout --embed-provider ollama --embed-model <model> <input.ssd>`"
}

segment HELP_LINE_5 {
  source: HELP_TOPIC
  text_quote: "Status:"
}

segment HELP_LINE_6 {
  source: HELP_TOPIC
  text_quote: "- This subcommand currently supports explicit Ollama-backed embedding generation from an existing `.ssd` input."
}

segment HELP_LINE_7 {
  source: HELP_TOPIC
  text_quote: "- Raw input extraction and non-Ollama providers remain planned but not implemented in the current slice."
}

segment HELP_LINE_8 {
  source: HELP_TOPIC
  text_quote: "Related help:"
}

segment HELP_LINE_9 {
  source: HELP_TOPIC
  text_quote: "- `ssd help grammar`"
}

segment HELP_LINE_10 {
  source: HELP_TOPIC
  text_quote: "- `ssd help troubleshooting`"
}
